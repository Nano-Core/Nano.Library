{
  "App": {
    "Version": "1.0.0.0",
    "Localization": {
      "DefaultCulture": "en-US"
    },
    "Apis": {
      "MyApi": {
        "Host": "localhost",
        "Root": "api",
        "Port": 80,
        "UseSsl": false,
        "Timeout": "00:00:30",
        "HealthCheck": {
          "UnhealthyStatus": "Degraded"
        },
        "LogIn": {
          "Username": "admin",
          "Password": "abc12|+d34DadD"
        }
      }
    }
  },
  "Data": {
    "BatchSize": 25,
    "BulkBatchSize": 500,
    "BulkBatchDelay": 1000,
    "QueryRetryCount": 0,
    "QueryIncludeDepth": 4,
    "UseAutoSave": true,
    "UseLazyLoading": false,
    "UseCreateDatabase": false,
    "UseMigrateDatabase": false,
    "UseSoftDeletetion": false,
    "UseSensitiveDataLogging": false,
    "UseAudit": false,
    "UseQuerySplittingBehavior": "SingleQuery",
    "DefaultCollation": null,
    "ConnectionString": "Server=myHost;Database=myDb;Uid=myUser;Pwd=myPassword",
    "Cache": {
      "MaxEntries": 5000,
      "ExpirationTimeout": "00:05:00",
      "ExpirationScanFrequency": "00:01:00",
      "ExpirationMode": "Sliding",
      "IgnoredTableNames": [
      ]
    },
    "Identity": {
      "User": {
        "IsUniqueEmailAddressRequired": true,
        "IsUniquePhoneNumberRequired": false,
        "AllowedUserNameCharacters": null,
        "DefaultRoles": [
          "administrator"
        ]
      },
      "SignIn": {
        "RequireConfirmedEmail": false,
        "RequireConfirmedPhoneNumber": false
      },
      "Lockout": {
        "AllowedForNewUsers": true,
        "MaxFailedAccessAttempts": 3,
        "DefaultLockoutTimeSpan": "00:30:00"
      },
      "Password": {
        "RequireDigit": false,
        "RequireNonAlphanumeric": false,
        "RequireLowercase": false,
        "RequireUppercase": false,
        "RequiredLength": 5,
        "RequiredUniqueCharacters": 0
      },
      "Authentication": {
        "ApiKey": {
          "Secret": null
        }
      }
    },
    "ConnectionPool": {
      "PoolSize": 1024
    },
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  },
  "Logging": {
    "LogLevel": "Debug",
    "LogLevelOverrides": [
      {
        "Namespace": "System",
        "LogLevel": "Warning"
      },
      {
        "Namespace": "Microsoft",
        "LogLevel": "Warning"
      }
    ]
  },
  "Eventing": {
    "Host": "rabbitmq",
    "VHost": "/",
    "Port": 5672,
    "UseSsl": false,
    "Timeout": "00:00:30",
    "Heartbeat": 60,
    "PrefetchCount": 50,
    "Credentials": {
      "Id": "rabbitm_user",
      "Secret": "password"
    },
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  },
  "Storage": {
    "ShareName": null,
    "Credentials": {
      "Id": null,
      "Secret": null
    },
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  }
}