	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Nano.App.Web\Nano.App.Web.csproj" />
		<ProjectReference Include="..\..\Nano.App\Nano.App.csproj" />
	</ItemGroup>

</Project>
